{
    "$schema": "https://turbo.build/json-schema.json",
    "globalDependencies": ["**/.env.local"],
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "outputs": ["dist/**", ".next/**", "build/**"],
        "cache": true
      },
      "lint": {
        "outputs": [],
        "cache": true
      },
      "type-check": {
        "outputs": [],
        "cache": true
      },
      "test": {
        "outputs": ["coverage/**"],
        "cache": false
      },
      "dev": {
        "cache": false,
        "persistent": true
      }
    }
  }