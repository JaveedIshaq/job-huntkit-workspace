# Copy to apps/api/.env and fill with real values (never commit .env)
# cp apps/api/.env.example apps/api/.env

# Architecture: Option A — NestJS JWT (see devdocs/huntkit-architecture.md)

# PostgreSQL (Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Auth (NestJS issues and verifies JWT — not Supabase Auth)
JWT_SECRET=change-me-use-long-random-string
JWT_EXPIRES_IN=7d

# OpenAI (platform.openai.com → API keys)
OPENAI_API_KEY=sk-...

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# RAG (job analyze retrieval threshold)
RAG_SCORE_THRESHOLD=0.70

# Production: CORS_ORIGIN=https://your-app.netlify.app
